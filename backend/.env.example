PORT=5000

# Admin seed credentials — used by: npm run seed:admin
ADMIN_EMAIL=admin@floodguard.lk
ADMIN_PASSWORD=change_me_before_deploying
# Local MongoDB:
# MONGO_URI=mongodb://localhost:27017/floodguard
#

MONGO_URI=mongodb://localhost:27017/floodguard

# OpenWeather forecast/current weather API
OPENWEATHER_API_KEY=your_openweather_key

# Twilio SMS. Use either TWILIO_FROM_NUMBER or TWILIO_MESSAGING_SERVICE_SID.
TWILIO_ACCOUNT_SID=AC89f2f6256cbaa2d95122730282eefb4e
TWILIO_AUTH_TOKEN=put_your_real_auth_token_here
TWILIO_MESSAGING_SERVICE_SID=MG2fc599b85c494acb9dd4befc411df84b
# TWILIO_FROM_NUMBER=+1234567890
TWILIO_TEST_TO_NUMBER=+94771234567

# SMTP for password reset emails. If SMTP_HOST/USER/PASS are missing,
# the code is logged to the backend console instead (demo fallback).
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FloodGuard <no-reply@floodguard.local>"
